<!DOCTYPE html><html lang="ar" dir="rtl"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>دليل مدارس بريدة - مشاريع الطاقة الشمسية</title><script src="https:<link rel="stylesheet" href="https:<script src="https:<link href="https:<script>tailwind.config = {theme: {extend: {colors: {primary: '#1565C0',solar: '#22C55E',dark: '#1E293B'},fontFamily: {arabic: ['Cairo', 'sans-serif']}}}}</script><style type="text/tailwindcss">@layer utilities {.map-container { height: calc(100vh - 72px); }.info-panel { transition: all 0.3s ease; }}</style></head><body class="font-arabic bg-gray-50 text-gray-800"><!-- رأس الصفحة --><header class="bg-white shadow-md h-[72px] flex items-center justify-between px-4 md:px-6 z-10 relative"><div class="flex items-center gap-2"><span class="text-solar text-2xl">☀️</span><h1 class="text-lg md:text-xl font-bold">مدارس بريدة - مشاريع الطاقة الشمسية</h1></div><input type="text" id="searchInput" placeholder="ابحث باسم المدرسة..." class="border border-gray-300 rounded-lg px-3 py-1.5 w-64 focus:outline-none focus:ring-1 focus:ring-primary"></header><!-- الخريطة --><main class="relative"><div id="map" class="map-container w-full"></div><!-- لوحة المعلومات --><div id="infoPanel" class="info-panel fixed bottom-0 md:top-20 md:right-4 w-full md:w-80 bg-white rounded-t-xl md:rounded-xl shadow-xl p-4 z-[600] translate-y-full md:translate-y-0 md:opacity-0"><div class="flex justify-between items-center mb-3"><h3 id="schoolName" class="font-bold text-lg text-dark">اسم المدرسة</h3><button onclick="closeInfo()" class="text-gray-500 text-xl hover:text-red-500">&times;</button></div><div id="schoolDetails" class="text-sm space-y-2 leading-relaxed"><!-- البيانات تظهر هنا --></div></div></main><script>const map = L.map('map').setView([26.358, 43.964], 11);L.tileLayer('https:attribution: '&copy; <a href="https:}).addTo(map);const schoolsData = [{"installNo":1,"name":"متوسطة أبي عبيدة - بنين","lat":26.3773443,"lng":43.953123,"meterSerial":"KFM2120660298585","meterNumber":"10091788928","voltage":"380V/3PH","breaker":"1600A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":2,"name":"ثانوية الامام الطحاوي ببريدة - بنين","lat":26.3784074,"lng":43.963361,"meterSerial":"KFM2020660207744","meterNumber":"10041261615","voltage":"220V/3PH","breaker":"2000A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":3,"name":"ابتدائية الفاروق ببريدة - بنين","lat":26.3145973,"lng":43.978819,"meterSerial":"KFM2020660194245","meterNumber":"10041839321","voltage":"380V/3PH","breaker":"1000A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":4,"name":"مجمع القيروان التعليمي ببريدة -القسم المتوسط- بنين","lat":26.3958145,"lng":43.932203,"meterSerial":"KFM2020660204662","meterNumber":"10041470203","voltage":"220V/3PH","breaker":"1600A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":5,"name":"ابتدائية عثمان بن عفان - بنين","lat":26.3643396,"lng":43.958131,"meterSerial":"KFM2020660194788","meterNumber":"10041458147","voltage":"380V/3PH","breaker":"1250A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":6,"name":"ابتدائية الفيصلية - بنين","lat":26.3507337,"lng":43.965037,"meterSerial":"KFM2020660205336","meterNumber":"10041394424","voltage":"380V/3PH","breaker":"1600A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":7,"name":"متوسطة سيبويه - بنين","lat":26.4123689,"lng":43.929204,"meterSerial":"KFM2020660187506","meterNumber":"10093142685","voltage":"380V/3PH","breaker":"1600","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":8,"name":"المتوسطة الخامسة والخمسون - بنات","lat":26.3272589,"lng":44.014789,"meterSerial":"SRM2320661033214","meterNumber":"10105752709","voltage":"380V/3PH","breaker":"1600A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":9,"name":"ثانوية قيس بن عاصم رضى الله عنه - بنين","lat":26.4122509,"lng":43.929471,"meterSerial":"KFM2020660187503","meterNumber":"10093149041","voltage":"380V/3PH","breaker":"1600A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":10,"name":"الثانوية الخامسة والعشرون ببريدة - مسارات - بنات","lat":26.3281213,"lng":44.02538,"meterSerial":"KFM2120660265817","meterNumber":"10041713114","voltage":"220V/3PH","breaker":"1250A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":11,"name":"مدرسة أم المؤمنين صفية بنت حيي للطفولة المبكرة والابتدائية ببريدة - بنات","lat":26.3582212,"lng":43.995437,"meterSerial":"KFM2120660301083","meterNumber":"10041960204?","voltage":"380V/3PH","breaker":"1600A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":12,"name":"الثانوية السابعة والعشرون ببريدة - مسارات - بنات","lat":26.3088757,"lng":44.040119,"meterSerial":"KFM2020660194383","meterNumber":"10090557873?","voltage":"380V/3PH","breaker":"1000A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":13,"name":"الابتدائية الثانية لتحفيظ القران ببريدة - بنات","lat":26.3414173,"lng":43.983019,"meterSerial":"KFM2020660211765","meterNumber":"10042006958?","voltage":"380V/3PH","breaker":"1250A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":14,"name":"الثانوية الخامسة ببريدة - بنات","lat":26.3731105,"lng":43.977384,"meterSerial":"KFM2020660205316","meterNumber":"10041964357?","voltage":"380V/3PH","breaker":"1250A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":15,"name":"الابتدائية السادسة والثلاثون ببريدة - بنات","lat":26.341744,"lng":43.982553,"meterSerial":"KFM2020660194922","meterNumber":"10041954781?","voltage":"380V/3PH","breaker":"1250A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":16,"name":"الابتدائية السابعة لتحفيظ القران ببريدة - بنات","lat":26.3129143,"lng":43.962908,"meterSerial":"KFM2120660263561","meterNumber":"10099573152?","voltage":"220V/3PH","breaker":"800A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":17,"name":"الثانوية الثالثة والعشرون ببريدة -بنات","lat":26.3872433,"lng":43.935161,"meterSerial":"KFM2020660195009","meterNumber":"10041789972?","voltage":"220V/3PH","breaker":"1250A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":18,"name":"المتوسطة السادسة والأربعون ببريدة - بنات","lat":26.3091706,"lng":44.039454,"meterSerial":"KFM2020660194381","meterNumber":"10090562499?","voltage":"380V/3PH","breaker":"800A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":19,"name":"ثانوية االمتنبي ببريدة - بنين","lat":26.3899722,"lng":43.965727,"meterSerial":"KFM2120660235942","meterNumber":"10041810520","voltage":"220V/3PH","breaker":"1250A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:{"installNo":20,"name":"الابتدائية الرابعة والاربعون ببريدة - بنات","lat":26.3791874,"lng":43.971439,"meterSerial":"KFM2020660205572","meterNumber":"10041468205?","voltage":"380V/3PH","breaker":"1250A","length":"-","contact":"-","ready":"-","comment":"-","mapsUrl":"https:];let markers = [];function renderSchools(searchText = "") {markers.forEach(m => map.removeLayer(m));markers = [];const filtered = schoolsData.filter(s => s.name && s.name.includes(searchText.trim()));filtered.forEach(school => {if (!school.lat || !school.lng) return;const lat = parseFloat(String(school.lat).replace(',', '.'));const lng = parseFloat(String(school.lng).replace(',', '.'));if (isNaN(lat) || isNaN(lng)) return;const marker = L.circleMarker([lat, lng], {radius: 7,fillColor: '#22C55E',color: '#fff',weight: 2,opacity: 1,fillOpacity: 0.9}).addTo(map);marker.bindTooltip(school.name, { direction: 'top' });marker.on('click', () => showInfo(school));markers.push(marker);});}function showInfo(s) {document.getElementById('schoolName').innerText = s.name;document.getElementById('schoolDetails').innerHTML = `<p><strong>🔢 الرقم التسلسلي:</strong> ${s.installNo || '-'}</p><p><strong>🔌 الجهد الكهربائي:</strong> ${s.voltage || '-'}</p><p><strong>⚡ سعة القاطع:</strong> ${s.breaker || '-'}</p><p><strong>📟 رقم العداد التسلسلي:</strong> ${s.meterSerial || '-'}</p><p><strong>📟 رقم العداد:</strong> ${s.meterNumber || '-'}</p><p><strong>📏 الطول التقريبي:</strong> ${s.length || '-'}</p><p><strong>📞 جهة الاتصال:</strong> ${s.contact || '-'}</p><p><strong>✅ جاهز للتركيب:</strong> ${s.ready || '-'}</p><p><strong>📝 ملاحظات:</strong> ${s.comment || '-'}</p><div class="mt-4 flex gap-2 flex-wrap"><a href="${s.mapsUrl || '#'}" target="_blank" class="bg-primary text-white px-2 py-1 rounded text-xs">📍 فتح في الخرائط</a></div>`;document.getElementById('infoPanel').classList.remove('translate-y-full', 'md:opacity-0');}function closeInfo() {document.getElementById('infoPanel').classList.add('translate-y-full', 'md:opacity-0');}document.getElementById('searchInput').addEventListener('input', e => {renderSchools(e.target.value);});renderSchools();</script></body></html>